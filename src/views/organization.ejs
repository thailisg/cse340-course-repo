<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <h2><%= organizationDetails.name %></h2>
        <img src="/images/<%= organizationDetails.logo_filename %>" alt="<%= organizationDetails.name %> logo">

        <p>Description: <%= organizationDetails.description %></p>

        <h3>Service Projects</h3>
        <ul class="list">
            <% projects.forEach(project => { %>
                <li>
                    <div class="card-info">
                        <div class="card-title">
                            <a href="/project/<%= project.project_id %>">
                                <%= project.title %>
                            </a>
                        </div>
                    </div>
                </li>
            <% }) %>
        </ul>
        <p><a class="btn-link" href="/edit-organization/<%= organizationDetails.organization_id %>">Edit Organization</a></p>
    </main>
    <%- include('partials/footer') %>