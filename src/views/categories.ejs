<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>Our categories!</h2>
        <ul class="ul-all">
            <% categories.forEach(category => { %>
                <li><a href="/category/<%= category.category_id%>"><%= category.name %></a></li>
            <% }) %>
        </ul>
        <br>
        <p><a href="/new-category">Create New Category</a></p>
    </main>

    <%- include('partials/footer') %>