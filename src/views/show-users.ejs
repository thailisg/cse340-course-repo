<%- include('partials/header') %>

<h1>All Users</h1>

<ul>
  <% users.forEach(user => { %>
    <li>
      <strong>Name:</strong> <%= user.name %> <br>
      <strong>Email:</strong> <%= user.email %> <br>
      <strong>Role:</strong> <%= user.role_name %>
    </li>
    <hr>
  <% }) %>
</ul>

<%- include('partials/footer') %>